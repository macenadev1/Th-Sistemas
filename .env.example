# ========================================
# CONFIGURAÇÃO DO BOT TELEGRAM
# ========================================

# ========================================
# CONFIGURAÇÃO DA APLICAÇÃO
# ========================================

NODE_ENV=production
PORT=3000
APP_URL=http://localhost:3000

# ========================================
# CONFIGURAÇÃO DO BANCO MYSQL
# ========================================

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=BomboniereERP
DB_CONNECTION_LIMIT=10

# Token do bot obtido do @BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Chat ID para receber notificações
# Para chat privado: número positivo (ex: 123456789)
# Para grupo: número negativo (ex: -1001234567890)
# Para descobrir o ID: adicione o bot e digite /groupid
TELEGRAM_CHAT_ID=

# ========================================
# EXEMPLO DE CONFIGURAÇÃO
# ========================================
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-1001234567890
